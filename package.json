{
  "name": "markdown-pedagogico",
  "private": true,
  "version": "0.0.0",
  "description": "Editor de escritorio open source para Markdown con motor pedagógico basado en AST, vista previa y exportación PDF.",
  "license": "MIT",
  "author": "Nestor Fernando De Leon Llanos",
  "homepage": "https://github.com/nestorfernando3/markdown-pedagogico",
  "bugs": {
    "url": "https://github.com/nestorfernando3/markdown-pedagogico/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nestorfernando3/markdown-pedagogico.git"
  },
  "keywords": [
    "markdown",
    "editor",
    "education",
    "pedagogy",
    "tauri",
    "react",
    "typescript",
    "desktop-app"
  ],
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "preinstall": "node ./scripts/check-node-version.mjs",
    "check:node": "node ./scripts/check-node-version.mjs",
    "check:types": "npx tsc --noEmit",
    "check:rust": "cd src-tauri && cargo check",
    "check:a11y": "npx vitest run src/components/Editor/__tests__/Editor.accessibility.test.tsx",
    "check:tests": "npx vitest run",
    "check:smoke:web": "bash scripts/playwright_smoke.sh",
    "check:smoke:training": "node scripts/playwright_training_smoke.mjs",
    "check:all": "npm run check:node && npm run check:types && npm run check:rust && npm run check:tests",
    "review:pdf": "python3 scripts/review_pdf.py",
    "dev": "vite --port 5173 --strictPort",
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --no-watch",
    "tauri:dev:watch": "tauri dev",
    "desktop:dev": "tauri dev --no-watch",
    "desktop:dev:watch": "tauri dev"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@shikijs/rehype": "^4.0.0",
    "@tauri-apps/api": "^1.6.0",
    "@types/mdast": "^4.0.4",
    "dictionary-es": "^4.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "katex": "^0.16.33",
    "mdast-util-toc": "^7.1.0",
    "mermaid": "^11.12.3",
    "nspell": "^2.1.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-deflist": "^1.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^1.6.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/nspell": "^2.1.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
